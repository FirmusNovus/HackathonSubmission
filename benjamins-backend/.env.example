# Public hostname for issuer + verifier endpoints. In dev: your ngrok-free.app URL. In prod: the deployed Vercel domain.
PUBLIC_HOSTNAME=https://bronchial-seventeen-salami.ngrok-free.dev

# Operator wallet private key. On anvil this is the standard account 0 key. Never commit a real key.
OPERATOR_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# RPC + chain. Defaults match anvil.
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337

# Optional SQLite path overrides. Each service defaults to a path under its own
# app dir (apps/{platform,bar-issuer,pid-issuer}/data/...) and you should
# normally leave these unset.
# DATABASE_PATH=./apps/platform/data/lexnova.db
# BAR_ISSUER_DB_PATH=./apps/bar-issuer/data/db.sqlite
# PID_ISSUER_DB_PATH=./apps/pid-issuer/data/db.sqlite

# Optional port overrides. Defaults: proxy=3000, bar-issuer=3001,
# pid-issuer=3002, platform=3010. The proxy fronts all three so external
# callers (ngrok, the wallet) only see port 3000.
# PROXY_PORT=3000
# BAR_ISSUER_PORT=3001
# PID_ISSUER_PORT=3002
# PLATFORM_PORT=3010

# Optional: override the lawyer-side dispute cooldown (seconds) for local testing.
# Production uses the contract constant LAWYER_DISPUTE_COOLDOWN = 30 days.
# DISPUTE_COOLDOWN_OVERRIDE=
