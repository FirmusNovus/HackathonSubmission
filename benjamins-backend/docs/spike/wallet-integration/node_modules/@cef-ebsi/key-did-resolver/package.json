{
  "name": "@cef-ebsi/key-did-resolver",
  "version": "2.1.1",
  "description": "Resolve `did:key` DID documents",
  "license": "EUPL-1.2",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "bitbucket",
    "url": "https://ec.europa.eu/digital-building-blocks/code/scm/ebsi/core-libs.git",
    "directory": "packages/key-did-resolver"
  },
  "type": "module",
  "exports": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "prepare": "yarn build",
    "build": "tsc -p tsconfig/tsconfig.build.esm.json",
    "clean": "rimraf dist coverage",
    "lint": "yarn lint:tsc",
    "lint:tsc": "tsc --noEmit --incremental false",
    "test": "vitest --run",
    "test:unit": "yarn test",
    "test:e2e": "echo \"Info: there's no e2e tests for @cef-ebsi/key-did-resolver\" && exit 0",
    "test:ci": "yarn test:unit --coverage --reporter=default"
  },
  "dependencies": {
    "did-resolver": "^4.1.0",
    "lodash.isplainobject": "^4.0.6",
    "multiformats": "^9.6.2",
    "uint8arrays": "3.1.1"
  },
  "devDependencies": {
    "@types/lodash.isplainobject": "^4.0.9",
    "jose": "^5.10.0",
    "type-fest": "^4.41.0"
  }
}
