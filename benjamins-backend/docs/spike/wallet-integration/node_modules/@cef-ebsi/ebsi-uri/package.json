{
  "name": "@cef-ebsi/ebsi-uri",
  "version": "1.0.1",
  "description": "EBSI URIs parser and serializer",
  "license": "EUPL-1.2",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "bitbucket",
    "url": "https://ec.europa.eu/digital-building-blocks/code/scm/ebsi/core-libs.git",
    "directory": "packages/ebsi-uri"
  },
  "type": "module",
  "exports": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "prepare": "yarn build",
    "build": "tsc -p tsconfig/tsconfig.build.esm.json",
    "clean": "rimraf dist coverage",
    "lint": "yarn lint:tsc",
    "lint:tsc": "tsc --noEmit --incremental false",
    "test": "vitest --run",
    "test:unit": "yarn test unit",
    "test:e2e": "echo \"Info: there's no e2e tests for @cef-ebsi/ebsi-uri\" && exit 0",
    "test:ci": "yarn test:unit --coverage --reporter=default"
  }
}
