# Copy this file to `.env` and fill in. The defaults below match a local
# anvil instance booted via `pnpm anvil`; that's all you need for dev.

# Mnemonic anvil derives its 10 accounts from. Custom mnemonic so MetaMask
# doesn't auto-import a busy default-anvil account history.
ANVIL_MNEMONIC="basket salmon giraffe unit wine chat pretty behind aim habit cattle donor"

# Operator wallet private key (anvil account 0 derived from ANVIL_MNEMONIC).
# Signs Deploy.s.sol broadcasts and AttestationManager.attestVerified* calls.
OPERATOR_PRIVATE_KEY=0x725845f3ba1d1f92b515f3805baabb18a05716dce583fd9cc2188494a5baa877

# RPC + chain. Defaults match `pnpm anvil`.
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
