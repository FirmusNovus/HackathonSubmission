# Public hostname for issuer + verifier endpoints. In dev: your ngrok-free.app URL.
PUBLIC_HOSTNAME=https://your-ngrok-host.ngrok-free.dev

# Mnemonic anvil derives its 10 accounts from. Custom (vs. anvil's default
# "test test ... junk") so MetaMask doesn't auto-import 650 historically-active
# accounts when you import this phrase. Generate via `cast wallet new-mnemonic`.
ANVIL_MNEMONIC="basket salmon giraffe unit wine chat pretty behind aim habit cattle donor"

# Operator wallet private key (anvil account 0 derived from ANVIL_MNEMONIC).
# Never commit a real key. Local-dev only.
OPERATOR_PRIVATE_KEY=0x725845f3ba1d1f92b515f3805baabb18a05716dce583fd9cc2188494a5baa877

# RPC + chain. Defaults match anvil.
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
NEXT_PUBLIC_CHAIN_ID=31337

# Public-facing URL (typically same as PUBLIC_HOSTNAME for dev).
PUBLIC_URL=https://your-ngrok-host.ngrok-free.dev

# Dev-only: when set to "1" the platform exposes a persona picker at /dev/personas
# and the /api/dev/login endpoint, both of which short-circuit OID4VP onboarding
# by writing EAS attestations directly from the operator key. Refuses to start
# in production.
DEV_BYPASS_EUDI=1

# Issuer + platform DBs (relative to each app's root).
PLATFORM_DB=apps/platform/data/db.sqlite
ISSUER_DB=apps/issuer/data/db.sqlite
