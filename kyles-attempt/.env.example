# SQLite database — file path is resolved relative to prisma/schema.prisma,
# so this lands the DB at prisma/dev.db. Created on first `prisma migrate` run.
DATABASE_URL="file:./dev.db"

# Auth (NextAuth v5)
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-me-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Web3 — get a project id from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="replace-me"

# Admin endpoint key (required by /api/admin/verify-lawyer)
ADMIN_API_KEY="replace-me-with-a-random-secret"

# Auto-verify pending lawyer applications after N seconds in dev mode (demo only).
# Leave unset / 0 in production.
DEV_AUTO_VERIFY_SECONDS="5"

# Mock-chain operator wallet (F1+). The single address that may attest
# capabilities and resolve disputes. Leave unset to use the seeded fallback
# (0x09e8a70811111111111111111111111111111bbb), which all F1 fixtures expect.
# OPERATOR_WALLET="0x..."

NODE_ENV="development"
