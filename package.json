{
  "name": "firmusnovus-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "dotenv -e .env -- concurrently -n proxy,web,issuer -c green,blue,magenta \"pnpm --filter @firmus/proxy dev\" \"pnpm --filter @firmus/web dev\" \"pnpm --filter @firmus/issuer dev\"",
    "dev:proxy": "dotenv -e .env -- pnpm --filter @firmus/proxy dev",
    "dev:web": "pnpm --filter @firmus/web dev",
    "dev:issuer": "pnpm --filter @firmus/issuer dev",
    "build": "pnpm --filter @firmus/web build && pnpm --filter @firmus/issuer build",
    "start": "dotenv -e .env -- concurrently -n proxy,web,issuer -c green,blue,magenta \"pnpm --filter @firmus/proxy start\" \"pnpm --filter @firmus/web start\" \"pnpm --filter @firmus/issuer start\"",
    "issuer:seed": "pnpm --filter @firmus/issuer seed",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint",
    "test:e2e": "pnpm --filter @firmus/web test:e2e",
    "test:e2e:dev": "pnpm --filter @firmus/web test:e2e:dev",
    "prisma:migrate": "pnpm --filter @firmus/web prisma:migrate",
    "prisma:seed": "pnpm --filter @firmus/web prisma:seed",
    "db:reset": "pnpm --filter @firmus/web db:reset",
    "anvil": "dotenv -e .env -- bash -c 'anvil --block-time 2 --accounts 10 --balance 100 --gas-price 0 --base-fee 0 ${ANVIL_MNEMONIC:+--mnemonic \"$ANVIL_MNEMONIC\"}'",
    "scripts:deploy": "dotenv -e .env -- bash -c 'cd contracts && forge script script/Deploy.s.sol --rpc-url ${RPC_URL:-http://127.0.0.1:8545} --broadcast'",
    "contracts:test": "cd contracts && forge test",
    "reset": "bash scripts/dev-reset.sh"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "dotenv-cli": "^8.0.0"
  },
  "pnpm": {
    "overrides": {
      "zod": "3.24.4"
    }
  }
}
